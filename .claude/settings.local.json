      "Bash(curl -s http://localhost:8000/health)",
      "Bash(curl -s http://localhost:8000/bookings/)",
      "Bash(curl -s http://localhost:8000/bookings/1)",
      "Bash(curl -s -X POST http://localhost:8000/bookings/ -H 'Content-Type: application/json' -d '{:*)",
